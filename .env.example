# ─────────────────────────────────────────────────────────────
# Studio 61: QR — environment variables
# Copy this file to .env.local and fill in the values.
# .env.local is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────

# Neon Postgres connection string (use the POOLED connection string).
# This app MUST use its OWN database — do not share the CRM or Forms DB.
# Dashboard: https://console.neon.tech → your project → Connection Details
DATABASE_URL=""

# Auth.js (NextAuth v5) session-encryption secret. REQUIRED.
# Generate one with:  openssl rand -base64 33   (or)   npx auth secret
AUTH_SECRET=""

# Public base URL of the app. Used for the dynamic QR short links (/q/[slug])
# and auth callbacks. No trailing slash.
#   local:      http://localhost:3000
#   production: https://qr.your-domain.com
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── CRM SSO (token handoff) ───────────────────────────────────────────────────
# Shared HMAC secret for verifying SSO handoff tokens minted by the CRM.
# Must be IDENTICAL to the value on the CRM and the Forms app. Generate once:
#   openssl rand -base64 32
SSO_SHARED_SECRET=""

# CRM portal URL — used for a "Return to portal" link on the sign-in page.
CRM_PORTAL_URL="https://client.studiosixty-one.com"
